{
  "name": "@decentralchain/signer",
  "version": "2.0.0",
  "description": "Official DecentralChain transaction signing orchestrator — securely connect any provider to sign and broadcast blockchain transactions without exposing private keys",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Decentral-America/signer.git"
  },
  "bugs": {
    "url": "https://github.com/Decentral-America/signer/issues"
  },
  "homepage": "https://github.com/Decentral-America/signer#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "license": "MIT",
  "author": "DecentralChain",
  "packageManager": "npm@11.9.0",
  "keywords": [
    "decentralchain",
    "dcc",
    "signer",
    "blockchain",
    "transactions",
    "provider",
    "wallet",
    "dapp",
    "web3",
    "crypto",
    "digital-assets",
    "smart-contracts",
    "decentralized",
    "sdk"
  ],
  "scripts": {
    "build": "tsup",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:publint": "publint",
    "check:exports": "attw --pack . --profile esm-only",
    "check:size": "size-limit",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build",
    "prepare": "lefthook install",
    "postversion": "npm publish",
    "postpublish": "git push",
    "lint:fix": "biome check --write .",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "dependencies": {
    "@decentralchain/node-api-js": "2.0.0",
    "@decentralchain/ts-lib-crypto": "2.0.0",
    "@decentralchain/ts-types": "2.0.0"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "15 kB"
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@decentralchain/transactions": "5.0.0",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsup": "8.5.1",
    "typed-ts-events": "^3.0.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
